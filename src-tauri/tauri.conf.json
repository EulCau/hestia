{
  "$schema": "https://raw.githubusercontent.com/nicr9/tauri-settings-schema/refs/heads/v2/schema.json",
  "productName": "Hestia",
  "version": "0.1.0",
  "identifier": "com.hestia.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Hestia",
        "width": 900,
        "height": 700,
        "resizable": true,
        "decorations": true
      },
      {
        "label": "companion",
        "title": "Hestia Companion",
        "url": "/?view=companion",
        "width": 240,
        "height": 340,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true
      },
      {
        "label": "companion_dialog",
        "title": "Hestia Companion Dialogue",
        "url": "/?view=companion_dialog",
        "width": 320,
        "height": 220,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
