{
  "$schema": "https://raw.githubusercontent.com/nicr9/tauri-settings-schema/refs/heads/v2/schema.json",
  "productName": "Hestia",
  "version": "0.1.0",
  "identifier": "com.hestia.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Hestia",
        "width": 900,
        "height": 780,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../assets/avatar-placeholder.png",
      "../assets/companion-cat-placeholder.png",
      "../assets/workflows/sdxl.json"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
